@page "/products"
@using WarehouseManager.Services
@using WarehouseManager.Models
@inject ProductService ProductsService

<h3>Προϊόντα</h3>

<div class="warehouse-form">
    <h4>Προσθήκη Προϊόντος</h4>
    <input @bind="newProduct.SKU" placeholder="Κωδικός"/>
    <input @bind="newProduct.Name" placeholder="Όνομα"/>
    <input @bind="newProduct.Category" placeholder="Κατηγορία"/>
    <input type="number" @bind="newProduct.Price" placeholder="Τιμή"/>
    <input type="number" @bind="newProduct.Stock" placeholder="Stock"/>
    <input type="number" @bind="newProduct.MinStock" placeholder="Ελάχιστο Stock"/>
    <button @onclick="AddProduct">Προσθήκη</button>
</div>

<div style="margin-bottom: 1rem;">
    <input @bind="searchTerm" @bind:event="oninput" placeholder="Αναζήτηση προϊόντος..." style="width: 300px; padding: 0.4rem 0.6rem;
border: 1px solid #ced4da; border-radius: 4px;"/>
</div>

@if (isEditing && editProduct != null)
{
    <div class="warehouse-form">
        <h4>Επεξεργασία Προϊόντος</h4>
        <input @bind="editProduct.SKU" placeholder="Κωδικός"/>
        <input @bind="editProduct.Name" placeholder="Όνομα"/>
        <input @bind="editProduct.Category" placeholder="Κατηγορία"/>
        <input type="number" @bind="editProduct.Price" placeholder="Τιμή"/>
        <input type="number" @bind="editProduct.Stock" placeholder="Stock"/>
        <input type="number" @bind="editProduct.MinStock" placeholder="Ελάχιστο Stock"/>
        <button @onclick="SaveEdit">Αποθήκευση</button>
        <button @onclick="() => isEditing = false">Άκυρο</button>
    </div>
}

@if (products == null)
{
    <p>Φόρτωση...</p>
}

else if (!products.Any())
{
    <p>Δεν υπάρχουν προϊόντα.</p>
}

else
{
    <table class="warehouse-table">
        <thead>
        <tr>
            <th>
                Κωδικός
            </th>
            <th>
                Όνομα
            </th>
            <th>
                Κατηγορία
            </th>
            <th>
                Τιμή
            </th>
            <th>
                Stock
            </th>
            <th>
                Ενέργειες
            </th>
        </tr>
        </thead>
        <tbody>
        @foreach (var product in products.Where(p => string.IsNullOrEmpty(searchTerm) || 
                                                     p.Name.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
                                                     p.SKU.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)))
        {
            <tr>
                <td>
                    @product.SKU
                </td>
                <td>
                    @product.Name
                </td>
                <td>
                    @product.Category
                </td>
                <td>
                    @product.Price €
                </td>
                <td>
                    @product.Stock
                </td>
                <td>
                    <button class="btn-delete" @onclick="() => DeleteProduct(product.Id)">Διαγραφή</button>
                    <button @onclick="() => StartEdit(product)">Επεξεργασία</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
@code {
    private string searchTerm = string.Empty;
    
    private List<Product>? products;

    private Product? editProduct = null;
    private bool isEditing = false;

    private void StartEdit(Product product)
    {
        editProduct = new Product
        {
            Id = product.Id,
            SKU = product.SKU,
            Name = product.Name,
            Category = product.Category,
            Price = product.Price,
            Stock = product.Stock,
            MinStock = product.MinStock
        };
        isEditing = true;
    }

    // Δημιουργουμε ενα αντιγραφο οταν αρχισουμε να κανουμε edit ! Ωστε αν πατησουμε cancel να υπαρχει το παλιο
    private async Task SaveEdit()
    {
        if (editProduct != null)
        {
            await ProductsService.UpdateAsync(editProduct);
            isEditing = false;
            editProduct = null;
            products = await ProductsService.GetAllAsync();
        }
    }

    private Product newProduct = new Product();

    private async Task AddProduct()
    {
        await ProductsService.AddAsync(newProduct);
        newProduct = new Product();
        products = await ProductsService.GetAllAsync();
    }

    protected override async Task OnInitializedAsync()
    {
        products = await ProductsService.GetAllAsync();
        
    }

    private async Task DeleteProduct(int id)
    {
        await ProductsService.DeleteAsync(id);
        products = await ProductsService.GetAllAsync();
    }

}